# =========================================================================
# KRAM Auction Platform — Environment Variables Example
# =========================================================================
# Copy this file to '.env' and fill in your actual production/local values.
# DO NOT commit real secrets or production keys to version control!

# 1. DATABASE CONFIGURATION (Prisma ORM)
# Local SQLite example: "file:./dev.db"
# Production Neon PostgreSQL example: "postgresql://username:password@ep-host.region.pooler.neon.tech/kram?sslmode=require"
DATABASE_URL="file:./dev.db"

# 2. AUTHENTICATION (Auth.js v5 / NextAuth.js)
# A secure, random string for token encryption (generate with: openssl rand -base64 32)
AUTH_SECRET="replace-with-random-auth-secret"
# Public URL of your application (localhost for development, your domain for production)
AUTH_URL="http://localhost:3002"
# Trust deployment host headers (needed for Vercel/proxies)
AUTH_TRUST_HOST=true

# 3. SOCIAL & OUTBOUND LINKS
# Official Telegram support/community channel URL
NEXT_PUBLIC_TELEGRAM_URL="https://t.me/kram_auction"
# Public application URL exposed to frontend
NEXT_PUBLIC_APP_URL="http://localhost:3002"

# 4. CRON JOBS & INTEGRATIONS
# Secret header required by /api/cron/* endpoints to secure auction closing cron jobs.
# On Vercel Hobby, schedule this externally instead of using Vercel Cron more than daily:
# GET /api/cron/close-auctions with x-cron-secret: $CRON_SECRET
CRON_SECRET="replace-with-random-cron-secret"

# 5. GOOGLE OAUTH CONFIGURATION (Social Login)
# Obtain these from the Google Cloud Console (APIs & Services > Credentials)
AUTH_GOOGLE_ID="your-google-oauth-client-id-here"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret-here"

# 6. DEEPSEEK AI INTEGRATION (Smart Listing Assistant)
# Obtain a key from the DeepSeek developer dashboard
DEEPSEEK_API_KEY="sk-your-deepseek-api-key-here"
DEEPSEEK_MODEL="deepseek-chat"

# 7. LIQPAY INTEGRATION (Payment Gateway)
# Public and Private keys can be found in your LiqPay dashboard (liqpay.ua)
LIQPAY_PUBLIC_KEY="your-liqpay-public-key"
LIQPAY_PRIVATE_KEY="your-liqpay-private-key"
# Enable Sandbox mode for testing payments without real money transfer ('true' or 'false')
LIQPAY_SANDBOX=true

# 8. SMS VERIFICATION (TurboSMS)
# Obtain a token from the TurboSMS API dashboard
TURBOSMS_TOKEN="your-turbosms-api-token"
TURBOSMS_SENDER="KRAM"

# 9. PRE-LAUNCH & ADS CONTROLS
# Set to 'false' in production to hide default demo accounts from the login page
NEXT_PUBLIC_SHOW_DEMO_ACCOUNTS=true
