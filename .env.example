# KRAM Marketplace — environment variables example
# Copy to .env.local for local dev or add in Vercel Project Settings → Environment Variables.

# -----------------------------------------------------------------------------
# CORE APP
# -----------------------------------------------------------------------------
# Local SQLite example:
DATABASE_URL="file:./dev.db"
# Production PostgreSQL example:
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Session signing secret (required in production)
AUTH_SECRET="replace-with-long-random-secret"
# Optional backward-compatible alias
NEXTAUTH_SECRET="replace-with-long-random-secret"

# Public app URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Optional auth URL aliases
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# GOOGLE LOGIN
# -----------------------------------------------------------------------------
# Use either GOOGLE_* or AUTH_GOOGLE_* (project supports both naming styles)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# Backward-compatible aliases:
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Authorized redirect URI in Google Cloud Console must include:
# https://your-domain.com/api/auth/google/callback

# -----------------------------------------------------------------------------
# STRIPE CHECKOUT
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_live_or_sk_test_your_secret_key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_or_pk_test_your_publishable_key"

# -----------------------------------------------------------------------------
# NOVA POSHTA
# -----------------------------------------------------------------------------
NOVA_POSHTA_API_KEY="your-nova-poshta-api-key"

# -----------------------------------------------------------------------------
# TELEGRAM
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
NEXT_PUBLIC_TELEGRAM_URL="https://t.me/your_bot_or_channel"

# -----------------------------------------------------------------------------
# CLOUDINARY IMAGE UPLOADS
# -----------------------------------------------------------------------------
# Preferred single-variable format:
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"
# Or split variables:
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-cloudinary-api-key"
# CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# -----------------------------------------------------------------------------
# DEEPSEEK AI ASSISTANT
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"
DEEPSEEK_MODEL="deepseek-chat"
