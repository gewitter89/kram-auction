DATABASE_URL="file:./dev.db"

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_me_with_long_random_secret

# Google OAuth (optional - button will show "Скоро" if not configured)
# See README for setup instructions
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Apple OAuth (optional - button will show "Скоро" if not configured)
# Requires Apple Developer Account
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
NEXT_PUBLIC_APPLE_CLIENT_ID=

# KRAM Beta Classified/Auction Mode Configuration
PAYMENTS_ENABLED=false
LIQPAY_ENABLED=false
SMS_ENABLED=false
KRAM_BETA_CLASSIFIED_MODE=true
NEXT_PUBLIC_KRAM_BETA_CLASSIFIED_MODE=true
